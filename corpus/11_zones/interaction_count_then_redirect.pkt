name: a count action runs before the redirect
source_fw: 'zone wan = [wan0]

  zone lan = [lan0, lan1, lan2, lan3]

  @xdp(lan)

  count fwd

  redirect to wan

  '
ingress_zone: lan
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="1.1.1.1", dst_port=80)
expected:
  compiles: true
  bpf_action: redirect
  redirect_zone: wan
  counter_changes:
    fwd: 1
