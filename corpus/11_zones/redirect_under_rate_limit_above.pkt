name: redirect modifier fires once the rate is exceeded
source_fw: 'zone wan = [wan0]

  zone lan = [lan0, lan1, lan2, lan3]

  @xdp(lan)

  redirect to wan if pkt.proto == tcp limited by rate_limit(10, per=src_ip)

  drop

  '
ingress_zone: lan
state:
  rate_limit:
    0:
      10.0.0.5: 15
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="1.1.1.1", dst_port=80)
expected:
  compiles: true
  bpf_action: redirect
  redirect_zone: wan
