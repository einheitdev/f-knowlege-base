name: redirect gated on a TCP flag
source_fw: 'zone wan = [wan0]

  zone lan = [lan0, lan1, lan2, lan3]

  @xdp(lan)

  redirect to wan if pkt.proto == tcp and pkt.tcp.syn

  drop

  '
ingress_zone: lan
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="1.1.1.1", dst_port=443, syn=true)
expected:
  compiles: true
  bpf_action: redirect
  redirect_zone: wan
