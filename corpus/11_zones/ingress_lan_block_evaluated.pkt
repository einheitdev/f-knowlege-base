name: the lan @xdp block governs lan-ingress packets
source_fw: 'zone wan = [wan0]

  zone lan = [lan0, lan1, lan2, lan3]

  @xdp(wan)

  drop

  @xdp(lan)

  redirect to wan

  '
ingress_zone: lan
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="8.8.8.8", dst_port=443)
expected:
  compiles: true
  bpf_action: redirect
  redirect_zone: wan
