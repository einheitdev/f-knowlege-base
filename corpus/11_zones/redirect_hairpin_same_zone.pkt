name: redirect back to the ingress zone (hairpin) is permitted
source_fw: 'zone wan = [wan0]

  zone lan = [lan0]

  zone dmz = [dmz0]

  @xdp(lan)

  redirect to lan

  '
ingress_zone: lan
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="10.0.0.9", dst_port=445)
expected:
  compiles: true
  bpf_action: redirect
  redirect_zone: lan
