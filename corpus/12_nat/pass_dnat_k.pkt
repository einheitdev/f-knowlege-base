name: "DNAT 198.51.100.15:80 -> 10.0.3.8:8000"
source_fw: |
  @xdp(wan)
  dnat to 10.0.3.8:8000 if pkt.proto == tcp and pkt.dst_port == 80
  allow
test_packet:
  builder: tcp(src_ip="151.101.64.1", dst_ip="198.51.100.15", src_port=36000, dst_port=80, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "151.101.64.1"
    dst_ip: "10.0.3.8"
    dst_port: 8000
