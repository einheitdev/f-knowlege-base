name: "masquerade alongside a count side effect"
source_fw: |
  @xdp(lan)
  count natted if pkt.proto == tcp
  masquerade if pkt.proto == tcp
  allow
state:
  nat:
    masq_ip: "203.0.113.7"
test_packet:
  builder: tcp(src_ip="10.0.0.5", dst_ip="1.1.1.1", src_port=12345, dst_port=80, syn=true)
expected:
  compiles: true
  bpf_action: allow
  counter_changes: { natted: 1 }
  output_packet:
    src_ip: "203.0.113.7"
