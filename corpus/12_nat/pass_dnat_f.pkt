name: "DNAT 198.51.100.10:80 -> 10.0.1.5:8080"
source_fw: |
  @xdp(wan)
  dnat to 10.0.1.5:8080 if pkt.proto == tcp and pkt.dst_port == 80
  allow
test_packet:
  builder: tcp(src_ip="45.33.0.1", dst_ip="198.51.100.10", src_port=30000, dst_port=80, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "45.33.0.1"
    dst_ip: "10.0.1.5"
    dst_port: 8080
