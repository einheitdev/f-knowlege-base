name: "de-NAT return -> 10.0.0.5"
source_fw: |
  @xdp(wan)
  snat to 1.1.1.1 if pkt.proto == udp
  allow
state:
  nat:
    mappings:
      - { proto: tcp, src_ip: "93.184.216.34", dst_ip: "198.51.100.9", src_port: 80, dst_port: 12345, new_ip: "10.0.0.5", new_port: 12345, nat_type: dnat }
test_packet:
  builder: tcp(src_ip="93.184.216.34", dst_ip="198.51.100.9", src_port=80, dst_port=12345, ack=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    dst_ip: "10.0.0.5"
    src_ip: "93.184.216.34"
