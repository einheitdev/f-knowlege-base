name: "SNAT TCP 10.6.0.1 -> 198.51.100.60 (dst 80)"
source_fw: |
  @xdp(lan)
  snat to 198.51.100.60 if pkt.proto == tcp and pkt.dst_port == 80
  allow
test_packet:
  builder: tcp(src_ip="10.6.0.1", dst_ip="52.84.0.1", src_port=6000, dst_port=80, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "198.51.100.60"
    dst_ip: "52.84.0.1"
    src_port: 6000
    dst_port: 80
