name: "SNAT UDP 192.168.1.50 -> 203.0.113.1"
source_fw: |
  @xdp(lan)
  snat to 203.0.113.1 if pkt.proto == udp
  allow
test_packet:
  builder: udp(src_ip="192.168.1.50", dst_ip="1.1.1.1", src_port=40000, dst_port=53)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "203.0.113.1"
    dst_ip: "1.1.1.1"
    src_port: 40000
    dst_port: 53
