name: "SNAT TCP 10.5.5.5 -> 203.0.113.55 (dst 443)"
source_fw: |
  @xdp(lan)
  snat to 203.0.113.55 if pkt.proto == tcp and pkt.dst_port == 443
  allow
test_packet:
  builder: tcp(src_ip="10.5.5.5", dst_ip="13.107.21.200", src_port=5000, dst_port=443, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "203.0.113.55"
    dst_ip: "13.107.21.200"
    src_port: 5000
    dst_port: 443
