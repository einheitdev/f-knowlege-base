name: "de-NAT return -> 172.16.0.9"
source_fw: |
  @xdp(wan)
  snat to 1.1.1.1 if pkt.proto == udp
  allow
state:
  nat:
    mappings:
      - { proto: tcp, src_ip: "8.8.8.8", dst_ip: "198.51.100.2", src_port: 53, dst_port: 51000, new_ip: "172.16.0.9", new_port: 51000, nat_type: dnat }
test_packet:
  builder: tcp(src_ip="8.8.8.8", dst_ip="198.51.100.2", src_port=53, dst_port=51000, ack=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    dst_ip: "172.16.0.9"
    src_ip: "8.8.8.8"
