name: "SNAT TCP 192.168.10.10 -> 198.51.100.50 (dst 443)"
source_fw: |
  @xdp(lan)
  snat to 198.51.100.50 if pkt.proto == tcp and pkt.dst_port == 443
  allow
test_packet:
  builder: tcp(src_ip="192.168.10.10", dst_ip="172.217.0.1", src_port=4000, dst_port=443, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "198.51.100.50"
    dst_ip: "172.217.0.1"
    src_port: 4000
    dst_port: 443
