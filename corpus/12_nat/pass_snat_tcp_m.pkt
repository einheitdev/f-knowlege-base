name: "SNAT TCP 10.7.7.7 -> 198.51.100.70 (dst 80)"
source_fw: |
  @xdp(lan)
  snat to 198.51.100.70 if pkt.proto == tcp and pkt.dst_port == 80
  allow
test_packet:
  builder: tcp(src_ip="10.7.7.7", dst_ip="199.232.0.1", src_port=8000, dst_port=80, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "198.51.100.70"
    dst_ip: "199.232.0.1"
    src_port: 8000
    dst_port: 80
