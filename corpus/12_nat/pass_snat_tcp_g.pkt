name: "SNAT TCP 10.3.4.5 -> 198.51.100.40 (dst 8080)"
source_fw: |
  @xdp(lan)
  snat to 198.51.100.40 if pkt.proto == tcp and pkt.dst_port == 8080
  allow
test_packet:
  builder: tcp(src_ip="10.3.4.5", dst_ip="23.20.0.1", src_port=2000, dst_port=8080, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "198.51.100.40"
    dst_ip: "23.20.0.1"
    src_port: 2000
    dst_port: 8080
