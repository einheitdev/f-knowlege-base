name: "de-NAT return -> 10.1.2.3"
source_fw: |
  @xdp(wan)
  snat to 1.1.1.1 if pkt.proto == udp
  allow
state:
  nat:
    mappings:
      - { proto: tcp, src_ip: "140.82.112.3", dst_ip: "203.0.113.250", src_port: 443, dst_port: 33333, new_ip: "10.1.2.3", new_port: 33333, nat_type: dnat }
test_packet:
  builder: tcp(src_ip="140.82.112.3", dst_ip="203.0.113.250", src_port=443, dst_port=33333, ack=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    dst_ip: "10.1.2.3"
    src_ip: "140.82.112.3"
