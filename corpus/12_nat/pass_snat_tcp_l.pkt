name: "SNAT TCP 192.168.50.2 -> 203.0.113.66 (dst 443)"
source_fw: |
  @xdp(lan)
  snat to 203.0.113.66 if pkt.proto == tcp and pkt.dst_port == 443
  allow
test_packet:
  builder: tcp(src_ip="192.168.50.2", dst_ip="185.199.108.1", src_port=7000, dst_port=443, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "203.0.113.66"
    dst_ip: "185.199.108.1"
    src_port: 7000
    dst_port: 443
