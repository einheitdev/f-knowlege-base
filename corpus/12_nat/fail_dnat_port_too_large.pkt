name: "dnat target port above 65535 is a compile error"
source_fw: |
  @xdp(wan)
  dnat to 10.0.0.5:70000 if pkt.proto == tcp
  drop
test_packet:
  builder: tcp(src_ip="1.1.1.1", dst_ip="2.2.2.2", src_port=40000, dst_port=80, syn=true)
expected:
  compiles: false
  compile_error_pattern: "out of range"
