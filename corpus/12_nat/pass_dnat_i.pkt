name: "DNAT 198.51.100.13:22 -> 10.0.2.7:22"
source_fw: |
  @xdp(wan)
  dnat to 10.0.2.7:22 if pkt.proto == tcp and pkt.dst_port == 22
  allow
test_packet:
  builder: tcp(src_ip="13.32.0.1", dst_ip="198.51.100.13", src_port=34000, dst_port=22, syn=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "13.32.0.1"
    dst_ip: "10.0.2.7"
    dst_port: 22
