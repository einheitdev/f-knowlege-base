name: "masquerade udp 10.0.0.20 -> 203.0.113.8"
source_fw: |
  @xdp(lan)
  masquerade if pkt.proto == udp
  allow
state:
  nat:
    masq_ip: "203.0.113.8"
test_packet:
  builder: udp(src_ip="10.0.0.20", dst_ip="8.8.8.8", src_port=5353, dst_port=53)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    src_ip: "203.0.113.8"
    dst_ip: "8.8.8.8"
    src_port: 5353
