name: "de-NAT return -> 192.168.1.50"
source_fw: |
  @xdp(wan)
  snat to 1.1.1.1 if pkt.proto == udp
  allow
state:
  nat:
    mappings:
      - { proto: tcp, src_ip: "1.1.1.1", dst_ip: "203.0.113.1", src_port: 443, dst_port: 40000, new_ip: "192.168.1.50", new_port: 40000, nat_type: dnat }
test_packet:
  builder: tcp(src_ip="1.1.1.1", dst_ip="203.0.113.1", src_port=443, dst_port=40000, ack=true)
expected:
  compiles: true
  bpf_action: allow
  output_packet:
    dst_ip: "192.168.1.50"
    src_ip: "1.1.1.1"
