name: "different src_ip has independent rate-limit count"
source_fw: |
  @xdp(eth0)
  drop if pkt.proto == tcp and pkt.dst_port == 22
       limited by rate_limit(3, per=src_ip)
  default allow

state:
  rate_limit:
    0:
      "1.2.3.4": 100

test_packet:
  builder: tcp(src_ip="5.6.7.8", dst_port=22)

expected:
  compiles: true
  # 5.6.7.8 has its own bucket; count=0 < 3 means the drop rule does
  # not fire for it, regardless of 1.2.3.4's saturated bucket.
  bpf_action: allow
