name: "rate_limit gate is gated by condition: udp packet doesn't reach gate"
source_fw: |
  @xdp(eth0)
  drop if pkt.proto == tcp and pkt.dst_port == 22
       limited by rate_limit(3, per=src_ip)
  default allow

state:
  rate_limit:
    0:
      "1.2.3.4": 0

test_packet:
  builder: udp(src_ip="1.2.3.4", dst_port=22)

expected:
  compiles: true
  bpf_action: allow
