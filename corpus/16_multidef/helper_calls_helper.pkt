name: "helper calls helper"
source_fw: |
  def a(pkt):
    if pkt.src_ip == 1.1.1.1:
      drop
  
  def b(pkt):
    a(pkt)
    if pkt.src_ip == 2.2.2.2:
      allow
  
  @xdp(eth0)
  def m(pkt):
    b(pkt)
    drop

test_packet:
  builder: tcp(src_ip="2.2.2.2", dst_ip="9.9.9.9", dst_port=80)

expected:
  compiles: true
  bpf_action: allow
