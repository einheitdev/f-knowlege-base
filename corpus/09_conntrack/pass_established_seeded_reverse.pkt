name: "reply matches a seeded entry via the reverse 5-tuple"
source_fw: |
  @xdp(eth0)
  allow if conntrack(pkt).state == established
  default drop
state:
  conntrack:
    - { src_ip: "1.2.3.4", dst_ip: "2.2.2.2", src_port: 12345, dst_port: 80, proto: tcp }
test_packet:
  builder: tcp(src_ip="2.2.2.2", dst_ip="1.2.3.4", src_port=80, dst_port=12345, ack=true)
expected:
  compiles: true
  bpf_action: allow
