name: "a packet to a different port than the seed reads new (5-tuple specific)"
source_fw: |
  @xdp(eth0)
  allow if conntrack(pkt).state == established
  default drop
state:
  conntrack:
    - { src_ip: "1.2.3.4", dst_ip: "2.2.2.2", src_port: 12345, dst_port: 80, proto: tcp }
test_packet:
  builder: tcp(src_ip="1.2.3.4", dst_ip="2.2.2.2", src_port=12345, dst_port=81, ack=true)
expected:
  compiles: true
  bpf_action: drop
