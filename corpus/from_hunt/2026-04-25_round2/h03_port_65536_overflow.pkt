name: "pkt.dst_port == 65536 is rejected"
# Spec FWL_V01_SPEC.md:404: "port value <N> outside valid range
# 0..65535". 65536 is one past the boundary, must be rejected.
source_fw: |
  @xdp(eth0)
  drop if pkt.proto == tcp and pkt.dst_port == 65536
  default allow

test_packet:
  builder: tcp(dst_port=80)

expected:
  compiles: false
