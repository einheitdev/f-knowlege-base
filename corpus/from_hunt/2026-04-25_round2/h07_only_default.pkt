name: "@xdp(eth0) plus default drop only — no rules"
# Spec FWL_V01_SPEC.md:619: "A program may have zero rules between the
# hook declaration and an optional default rule." Should compile and
# drop every packet.
source_fw: |
  @xdp(eth0)
  default drop

test_packet:
  builder: tcp(dst_port=80)

expected:
  compiles: true
  bpf_action: drop
