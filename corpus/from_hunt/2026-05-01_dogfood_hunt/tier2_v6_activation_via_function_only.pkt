name: "Tier 2: v6 active via function body — dst_port read on v6 packet"
source_fw: |
  @xdp(eth0)
  def firewall(pkt):
    if pkt.src_ip6 in fc00::/7:
      allow
    if pkt.proto == tcp and pkt.dst_port == 80:
      allow
    drop

test_packet:
  builder: tcp6(src_ip="2001:db8::dead", dst_ip="2001:db8::cafe", dst_port=80)

expected:
  compiles: true
  bpf_action: allow
