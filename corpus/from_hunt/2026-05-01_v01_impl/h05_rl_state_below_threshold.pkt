name: "rate_limit does NOT fire when bucket count == threshold-1"
# Hypothesis: state count=9 + threshold=10 => below threshold, doesn't
# fire. Falls through to default allow.
source_fw: |
  @xdp(eth0)
  drop if pkt.proto == tcp and pkt.dst_port == 22
       limited by rate_limit(10, per=src_ip)
  default allow

state:
  rate_limit:
    0:
      "1.2.3.4": 9

test_packet:
  builder: tcp(src_ip="1.2.3.4", dst_port=22)

expected:
  compiles: true
  bpf_action: allow
