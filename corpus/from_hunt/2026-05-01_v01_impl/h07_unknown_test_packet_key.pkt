name: "loader silently accepts unknown test_packet field"
# Hypothesis (PKT_V01_SPEC.md:39): "Extra keys inside test_packet,
# expected, or state are also errors." truncate_to is documented but
# not implemented (status table line 81 says cases that use it
# "will fail to load until the loader gains the field"). The loader
# doesn't currently reject. Either truncation should work or unknown
# test_packet keys should be rejected — both are spec violations.
source_fw: |
  @xdp(eth0)
  allow

test_packet:
  builder: tcp(src_ip="1.2.3.4")
  truncate_to: 34

expected:
  loads: false
  compiles: true
  bpf_action: allow
