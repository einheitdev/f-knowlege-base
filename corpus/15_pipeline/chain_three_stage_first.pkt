name: "chain three stage first"
source_fw: |
  @xdp(eth0)
  drop if pkt.dst_ip == 9.9.9.9
  chain b
  allow if pkt.src_ip == 1.1.1.1
  chain c
  allow if pkt.proto == udp
  default drop

test_packet:
  builder: tcp(src_ip="1.1.1.1", dst_ip="9.9.9.9", dst_port=80)

expected:
  compiles: true
  bpf_action: drop
