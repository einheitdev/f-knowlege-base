name: "log action does not terminate evaluation; subsequent rule fires"
source_fw: |
  @xdp(eth0)
  log if pkt.proto == tcp and pkt.dst_port == 22
  drop if pkt.proto == tcp and pkt.dst_port == 22
  default allow

test_packet:
  builder: tcp(dst_port=22)

expected:
  compiles: true
  bpf_action: drop
