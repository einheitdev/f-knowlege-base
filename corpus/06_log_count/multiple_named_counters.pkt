name: "multiple distinct counter names compile and route packets correctly"
source_fw: |
  @xdp(eth0)
  count http_traffic  if pkt.proto == tcp and pkt.dst_port == 80
  count https_traffic if pkt.proto == tcp and pkt.dst_port == 443
  allow if pkt.proto == tcp and pkt.dst_port in [80, 443]
  default drop

test_packet:
  builder: tcp(dst_port=443)

expected:
  compiles: true
  bpf_action: allow
