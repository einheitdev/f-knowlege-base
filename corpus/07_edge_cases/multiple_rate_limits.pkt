name: "two rate_limits in same program get independent map slots"
source_fw: |
  @xdp(eth0)
  drop if pkt.proto == tcp and pkt.dst_port == 22
       limited by rate_limit(3, per=src_ip)
  drop if pkt.proto == tcp and pkt.dst_port == 23
       limited by rate_limit(5, per=src_ip)
  default allow

state:
  rate_limit:
    1:
      "1.2.3.4": 5

test_packet:
  builder: tcp(src_ip="1.2.3.4", dst_port=23)

expected:
  compiles: true
  bpf_action: allow
